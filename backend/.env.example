SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# DB_ENGINE = sqlite (default, zero setup, good for local dev)
#           = postgres (use this when pointing at Supabase or any Postgres)
DB_ENGINE=sqlite

# Only needed when DB_ENGINE=postgres (e.g. Supabase later)
DB_NAME=bug_tracker
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
